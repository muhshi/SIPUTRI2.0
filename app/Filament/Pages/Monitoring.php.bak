    public function table(Table $table): Table
    {
        $month = $this->data['month'] ?? now()->format('m');
        $year = $this->data['year'] ?? now()->format('Y');

        return $table
            ->query(
                PegawaiPst::query()
                    ->addSelect([
                        'jml_layanan' => Kunjungan::selectRaw('count(*)')
                            ->whereColumn('pegawai_id', 'pegawai_psts.id')
                            ->whereMonth('tanggal', $month)
                            ->whereYear('tanggal', $year),

                        'avg_durasi' => Kunjungan::selectRaw('avg(timestampdiff(SECOND, waktu_mulai, waktu_selesai))')
                            ->whereColumn('pegawai_id', 'pegawai_psts.id')
                            ->whereMonth('tanggal', $month)
                            ->whereYear('tanggal', $year)
                            ->whereNotNull('waktu_mulai')
                            ->whereNotNull('waktu_selesai'),

                        'avg_evaluasi' => Evaluasi::selectRaw('avg(rating)')
                            ->whereColumn('pegawai_id', 'pegawai_psts.id')
                            ->whereMonth('tanggal_evaluasi', $month)
                            ->whereYear('tanggal_evaluasi', $year),
                    ])
            )
            ->columns([
                TextColumn::make('nama_pegawai')
                    ->label('Nama Pegawai')
                    ->sortable()
                    ->searchable(),

                TextColumn::make('jml_layanan')
                    ->label('Jumlah Layanan')
                    ->suffix(' Layanan')
                    ->sortable(),

                TextColumn::make('avg_durasi')
                    ->label('Durasi Rata-rata')
                    ->formatStateUsing(function ($state) {
                        if (!$state)
                            return '---';
                        $minutes = floor($state / 60);
                        $seconds = $state % 60;
                        return "{$minutes}m {$seconds}s";
                    })
                    ->sortable(),

                TextColumn::make('avg_evaluasi')
                    ->label('Rating Rata-rata')
                    ->numeric(decimalPlaces: 1)
                    ->suffix(' / 5.0')
                    ->sortable(),
            ])
            ->filters([
                // Filters are handled by the custom form for real-time update in this custom page
            ]);
    }
}
